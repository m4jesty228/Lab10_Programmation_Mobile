<?xml version="1.0" encoding="utf-8"?>
<!-- En-tête du panneau Navigation Drawer -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="180dp"
    android:background="#3F51B5"
    android:gravity="bottom"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Photo de profil ronde via l'icône du projet -->
    <ImageView
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:src="@mipmap/ic_launcher_round"
        android:contentDescription="Avatar"/>

    <!-- Nom affiché dans l'en-tête -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Majesty"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginTop="8dp"/>

    <!-- Email ou description -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ENSA Marrakech — GCDSTE S4"
        android:textColor="#C5CAE9"
        android:textSize="12sp"/>

</LinearLayout>